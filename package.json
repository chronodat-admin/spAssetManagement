{
  "name": "asset-management-spfx",
  "version": "1.0.0.3",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "gulp bundle",
    "clean": "gulp clean",
    "serve": "gulp serve",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "npm run build && node --test scripts/listItemQueryTests.mjs scripts/seedDedupTests.mjs scripts/notificationTests.mjs scripts/sampleDataSeedTests.mjs scripts/graphMailSendTests.mjs scripts/mergeCustomFieldsTests.mjs scripts/emailIntegrationTests.mjs scripts/numberingTests.mjs scripts/listFormMutationTests.mjs scripts/assignmentTests.mjs scripts/depreciationTests.mjs scripts/assetListFilterTests.mjs scripts/assetDashboardStatsTests.mjs",
    "test:spfx": "gulp test",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "sync:publisher": "node scripts/sync-publisher-manifests.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "verify:version": "node scripts/verify-version-sync.mjs",
    "verify:display-name": "node scripts/verify-app-display-name.mjs",
    "verify:store": "node scripts/verify-store-readiness.mjs && node scripts/verify-store-screenshots.mjs",
    "assets:sppkg": "python scripts/prepare-sppkg-assets.py",
    "teams:package": "powershell -ExecutionPolicy Bypass -File teams/build-package.ps1",
    "teams:package:m365": "powershell -ExecutionPolicy Bypass -File teams/build-package.ps1 -IncludeM365",
    "fix:sppkg-teams": "powershell -ExecutionPolicy Bypass -File scripts/fix-sppkg-teams.ps1",
    "docs:architecture": "python scripts/build-architecture-doc.py",
    "docs:user-guide": "python scripts/build-user-guide.py",
    "docs:user-guide:capture": "playwright test e2e/screenshots/capture-user-guide.spec.ts",
    "docs:user-guide:all": "npm run docs:user-guide:capture && npm run docs:user-guide",
    "docs:word": "python scripts/build-architecture-doc.py && python scripts/build-user-guide.py",
    "docs:marketing": "python scripts/build-marketing-images.py",
    "assets:marketing": "python scripts/generate-marketing-one-pagers.py",
    "assets:marketing:crops": "python scripts/generate-marketing-store-crops.py",
    "assets:marketing:all": "npm run docs:marketing && npm run assets:marketing && npm run assets:marketing:crops",
    "assets:architecture": "node scripts/render-architecture.mjs && python scripts/embed-chronodat-logo.py",
    "assets:infographic": "python scripts/embed-chronodat-logo.py --ai",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:setup": "playwright test --project=setup --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "ship": "node scripts/sync-publisher-manifests.mjs && node scripts/sync-version.mjs && npm run teams:package:m365 && npm run assets:sppkg && node scripts/clean-release.mjs && gulp bundle --ship && gulp package-solution --ship && npm run fix:sppkg-teams"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.330",
    "@microsoft/sp-component-base": "1.21.1",
    "@microsoft/sp-core-library": "1.21.1",
    "@microsoft/sp-http": "1.21.1",
    "@microsoft/sp-listview-extensibility": "1.21.1",
    "@microsoft/sp-lodash-subset": "1.21.1",
    "@microsoft/sp-office-ui-fabric-core": "1.21.1",
    "@microsoft/sp-property-pane": "1.21.1",
    "@microsoft/sp-webpart-base": "1.21.1",
    "@pnp/graph": "^4.4.0",
    "@pnp/logging": "^4.4.0",
    "@pnp/queryable": "^4.4.0",
    "@pnp/sp": "^4.4.0",
    "date-fns": "^3.6.0",
    "jspdf": "^2.5.2",
    "jsbarcode": "^3.11.6",
    "papaparse": "^5.4.1",
    "qrcode": "^1.5.4",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "recharts": "^2.12.7",
    "tslib": "2.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@microsoft/eslint-config-spfx": "1.21.1",
    "@microsoft/eslint-plugin-spfx": "1.21.1",
    "@microsoft/rush-stack-compiler-5.3": "0.1.0",
    "@microsoft/sp-build-web": "1.21.1",
    "@microsoft/sp-module-interfaces": "1.21.1",
    "@playwright/test": "^1.52.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.3.15",
    "@types/qrcode": "^1.5.5",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "1.15.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "gulp": "4.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "scheduler": "^0.20.2",
    "ts-jest": "^29.4.11",
    "typescript": "~5.3.3"
  }
}
